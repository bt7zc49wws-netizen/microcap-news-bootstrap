APP_NAME=microcap-news
APP_ENV=dev
APP_PORT=8000
LOG_LEVEL=INFO

POSTGRES_DB=microcap
POSTGRES_USER=app
POSTGRES_PASSWORD=app
POSTGRES_HOST=db
POSTGRES_PORT=5432

WORKER_POLL_SECONDS=2
SCHEDULER_INTERVAL_SECONDS=30
FRESHNESS_THRESHOLD_SECONDS=120
SCHEMA_VERSION=v1
BUILD_VERSION=0.1.0

LIVE_SOURCE_ENABLED=false
LIVE_SOURCE_URL=https://www.prnewswire.com/rss/news-releases-list.rss
LIVE_SOURCE_POLL_INTERVAL_SECONDS=300
LIVE_SOURCE_TIMEOUT_SECONDS=15
LIVE_SOURCE_MAX_ITEMS_PER_RUN=100
LIVE_SOURCE_STALENESS_THRESHOLD_SECONDS=259200

# External data providers
BENZINGA_API_KEY=
MARKET_DATA_PROVIDER=none
POLYGON_API_KEY=
TIINGO_API_KEY=
SEC_EDGAR_USER_AGENT=
FUNDAMENTALS_PROVIDER=none
FINNHUB_API_KEY=
FMP_API_KEY=
